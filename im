<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<title>AI 圖生影片 1 分鐘網站</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
body{margin:0;font-family:"Microsoft JhengHei",Arial;background:#101827;color:white}
header,main,section,article,footer{box-sizing:border-box}
header{text-align:center;padding:30px;background:#1e293b}
main{max-width:900px;margin:auto;padding:20px}
section,article{background:#ffffff18;padding:18px;margin:18px 0;border-radius:18px}
input,textarea,select,button{width:100%;padding:12px;margin-top:8px;border-radius:12px;border:none;font-size:16px;box-sizing:border-box}
textarea{min-height:130px}
button{background:#facc15;font-weight:bold;cursor:pointer}
img,video{width:100%;border-radius:16px;background:#000}
progress{width:100%;height:24px}
</style>
</head>
<body>

<header>
<h1>AI 圖生影片 1 分鐘網站</h1>
<p>上傳圖片 → 選 AI 模型 → 後端呼叫影片 API</p>
</header>

<main>

<section>
<h2>上傳圖片</h2>
<input id="imageInput" type="file" accept="image/*">
<img id="previewImage" alt="圖片預覽">
</section>

<section>
<h2>影片設定</h2>

<label>AI 模型</label>
<select id="modelInput">
<option value="sora-2">sora-2</option>
<option value="sora-2-pro">sora-2-pro</option>
</select>

<label>影片提示詞</label>
<textarea id="promptInput">動漫風格，角色慢慢靠近鏡頭，背景有發光粒子，電影感運鏡，夢幻奇幻氣氛。</textarea>

<label>影片秒數</label>
<select id="secondsInput">
<option value="60">60 秒</option>
<option value="30">30 秒</option>
<option value="15">15 秒</option>
</select>

<button onclick="generateVideo()">生成 AI 影片</button>

<p id="statusText">狀態：等待上傳圖片</p>
<progress id="progressBar" value="0" max="100"></progress>
</section>

<section>
<h2>生成結果</h2>
<video id="videoResult" controls></video>
<a id="downloadLink" href="#" download="ai-video.mp4">下載影片</a>
</section>

</main>

<footer>
<p>API Key 只能放在後端，不能放在 HTML 前端。</p>
</footer>

<script>
const imageInput = document.getElementById("imageInput");
const previewImage = document.getElementById("previewImage");
const statusText = document.getElementById("statusText");
const progressBar = document.getElementById("progressBar");
const videoResult = document.getElementById("videoResult");
const downloadLink = document.getElementById("downloadLink");

let selectedFile = null;

imageInput.addEventListener("change",function(){
  selectedFile = imageInput.files[0];

  if(!selectedFile){
    statusText.textContent = "狀態：沒有選擇圖片";
    return;
  }

  previewImage.src = URL.createObjectURL(selectedFile);
  statusText.textContent = "狀態：圖片已上傳";
});

async function generateVideo(){
  if(!selectedFile){
    statusText.textContent = "狀態：請先上傳圖片";
    return;
  }

  const formData = new FormData();
  formData.append("image",selectedFile);
  formData.append("model",document.getElementById("modelInput").value);
  formData.append("prompt",document.getElementById("promptInput").value);
  formData.append("seconds",document.getElementById("secondsInput").value);

  statusText.textContent = "狀態：正在送出 AI 影片任務...";
  progressBar.value = 10;

  const createResponse = await fetch("http://localhost:3000/api/generate-video",{
    method:"POST",
    body:formData
  });

  const createData = await createResponse.json();

  if(!createData.success){
    statusText.textContent = "狀態：生成失敗：" + createData.message;
    return;
  }

  const videoId = createData.videoId;
  progressBar.value = 30;
  statusText.textContent = "狀態：AI 正在生成影片...";

  let finished = false;

  while(!finished){
    await new Promise(resolve => setTimeout(resolve,5000));

    const statusResponse = await fetch("http://localhost:3000/api/video-status/" + videoId);
    const statusData = await statusResponse.json();

    if(statusData.status === "completed"){
      finished = true;
      progressBar.value = 100;
      statusText.textContent = "狀態：影片生成完成";

      const videoUrl = "http://localhost:3000/api/video-download/" + videoId;
      videoResult.src = videoUrl;
      downloadLink.href = videoUrl;
    }else if(statusData.status === "failed"){
      finished = true;
      statusText.textContent = "狀態：影片生成失敗";
    }else{
      progressBar.value = Math.min(progressBar.value + 10,90);
      statusText.textContent = "狀態：生成中，目前狀態：" + statusData.status;
    }
  }
}
</script>

</body>
</html>
